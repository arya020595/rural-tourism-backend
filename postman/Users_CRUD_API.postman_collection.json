    {
      "name": "Operator Admin – Cross-Company (403)",
      "description": "Tests that an operator_admin CANNOT access users belonging to a different company.\n\n**How to test:**\n1. Run **Login (Operator Admin)** first (auto-sets `{{token}}`)\n2. Set `{{otherCompanyUserId}}` to the ID of a user in a DIFFERENT company\n3. Run each request — all should return 403",
      "item": [
        {
          "name": "Get User (other company) – 403",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 403', function () {",
                  "    pm.response.to.have.status(403);",
                  "});",
                  "",
                  "pm.test('Cross-company access denied', function () {",
                  "    const res = pm.response.json();",
                  "    pm.expect(res.success).to.eql(false);",
                  "    pm.expect(res.message).to.contain('within your own company');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{otherCompanyUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{otherCompanyUserId}}"]
            },
            "description": "Operator admin tries to GET a user from another company. Expects 403.\n\nPolicy: `UserPolicy.show()` → `_sameScope()` returns false → 403."
          }
        },
        {
          "name": "Update User (other company) – 403",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 403', function () {",
                  "    pm.response.to.have.status(403);",
                  "});",
                  "",
                  "pm.test('Cross-company update denied', function () {",
                  "    const res = pm.response.json();",
                  "    pm.expect(res.success).to.eql(false);",
                  "    pm.expect(res.message).to.contain('within your own company');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
