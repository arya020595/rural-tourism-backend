    {
      "name": "RBAC – Access Denied (403)",
      "description": "These requests demonstrate 403 Forbidden responses when the logged-in user lacks the required permissions.\n\n**How to test:**\n1. Run **Login (Operator Staff – no user perms)** or **Login (Association – no user perms)** first\n2. Then run any request in this folder — all should return 403",
      "item": [
        {
          "name": "List Users – 403 (no user:read)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 403', function () {",
                  "    pm.response.to.have.status(403);",
                  "});",
                  "",
                  "pm.test('Forbidden response with required permissions', function () {",
                  "    const res = pm.response.json();",
                  "    pm.expect(res.success).to.eql(false);",
                  "    pm.expect(res.message).to.contain('Forbidden');",
                  "    pm.expect(res.data.required).to.include('user:read');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Expects 403. Login as operator staff or association first (no `user:read` permission)."
          }
        },
