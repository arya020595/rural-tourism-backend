              "raw": "{{baseUrl}}/api/users/{{otherCompanyUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{otherCompanyUserId}}"]
            },
            "description": "Operator admin tries to UPDATE a user from another company. Expects 403.\n\nPolicy: `UserPolicy.update()` → `_sameScope()` returns false → 403."
          }
        },
        {
          "name": "Delete User (other company) – 403",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 403', function () {",
                  "    pm.response.to.have.status(403);",
                  "});",
                  "",
                  "pm.test('Cross-company delete denied', function () {",
                  "    const res = pm.response.json();",
                  "    pm.expect(res.success).to.eql(false);",
