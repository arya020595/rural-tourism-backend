                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"association_seed\",\n  \"password\": \"association123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login as association user. Has NO user:* permissions — expect 403 on users endpoints. Only has profile, association, accommodation, activity, booking permissions."
          }
        }
      ]
    },
    {
      "name": "Users CRUD",
      "description": "Core CRUD operations on the `users` table.",
      "item": [
        {
          "name": "List All Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has success envelope with pagination', function () {",
                  "    const res = pm.response.json();",
                  "    pm.expect(res.success).to.eql(true);",
                  "    pm.expect(res).to.have.property('data');",
                  "    pm.expect(res.data).to.be.an('array');",
                  "    pm.expect(res).to.have.property('pagination');",
                  "    pm.expect(res.pagination).to.have.property('total');",
                  "    pm.expect(res.pagination).to.have.property('page');",
                  "    pm.expect(res.pagination).to.have.property('per_page');",
                  "    pm.expect(res.pagination).to.have.property('total_pages');",
                  "    pm.expect(res.pagination).to.have.property('has_next');",
                  "    pm.expect(res.pagination).to.have.property('has_prev');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users?page=1&per_page=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (default: 1)"
                },
                {
                  "key": "per_page",
                  "value": "10",
                  "description": "Items per page (default: 10)"
                },
                {
                  "key": "search",
                  "value": "",
                  "description": "Search name + email (LIKE)",
                  "disabled": true
                },
                {
                  "key": "q[name_cont]",
                  "value": "",
                  "description": "Ransack: name contains",
                  "disabled": true
                },
                {
                  "key": "sort",
                  "value": "name_asc",
                  "description": "Sort field + direction (e.g. name_desc, id_asc)",
                  "disabled": true
                }
              ]
            },
            "description": "List all users with search, filter, sort and pagination.\n\n**Permission**: `user:read`\n\n**Query params:**\n- `page` / `per_page` – pagination (defaults: 1 / 10)\n- `search` – shortcut: searches `name` + `email` (LIKE)\n- `q[field_pred]` – Ransack predicates (cont, eq, gt, lt, in, etc.)\n- `sort` – e.g. `name_desc`, `id_asc` (or `sort=name&order=DESC`)"
          }
        },
        {
          "name": "Get User by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has user data', function () {",
                  "    const res = pm.response.json();",
                  "    pm.expect(res.success).to.eql(true);",
                  "    pm.expect(res.data).to.have.property('id');",
                  "    pm.expect(res.data).to.have.property('username');",
                  "    pm.expect(res.data).to.have.property('email');",
                  "    pm.expect(res.data).to.not.have.property('password');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{userId}}"]
            },
            "description": "Get a single user by ID.\n\n**Permission**: `user:read` or `profile:read` (own resource only)"
          }
        },
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('User created successfully', function () {",
                  "    const res = pm.response.json();",
                  "    pm.expect(res.success).to.eql(true);",
                  "    pm.expect(res.message).to.eql('User created successfully');",
                  "    pm.expect(res.data).to.have.property('id');",
                  "});",
                  "",
                  "// Save the new user ID for subsequent requests",
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "    pm.collectionVariables.set('userId', res.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Test User\",\n  \"username\": \"new_test_user\",\n  \"email\": \"newtest@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Create a new user (requires auth + `user:create` permission).\n\n**Superadmin**: can pass `role_id`, `company_id`, `association_id` freely.\n**Operator Admin**: `role_id` and `company_id` are auto-assigned (operator_staff role + caller's company_id).\n\nThe created user's ID is saved to `{{userId}}` for use in subsequent requests."
          }
        },
        {
