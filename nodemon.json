{
  "watch": [
    "server.js",
    "bin/",
    "routes/",
    "controllers/",
    "models/",
    "middleware/",
    "config/",
    "utils/"
  ],
  "ignore": [
    "node_modules/",
    "tests/",
    "coverage/",
    "uploads/",
    "*.test.js",
    "*.spec.js"
  ],
  "ext": "js,json",
  "exec": "node server.js",
  "env": {
    "NODE_ENV": "development"
  },
  "delay": 500
}
