# ==================================
# RT Backend Environment Configuration
# ==================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rural_tourism
DB_USER=root
DB_PASSWORD=your_database_password

# Server Configuration
PORT=3000
NODE_ENV=development
# NODE_ENV=production  # Use this in production

# CORS Configuration
# Add allowed origins for your frontend applications
CORS_ORIGIN=http://localhost:8100
CORS_ORIGIN2=http://localhost:4200
CORS_ORIGIN_EXTERNAL=https://your-production-domain.com

# JWT Configuration
# Replace with a secure random string, for example:
# openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING
JWT_EXPIRES_IN=24h

# File Upload Configuration
MAX_FILE_SIZE=1mb
UPLOAD_PATH=./uploads

# SSL Configuration (for HTTPS - optional)
# SSL_KEY_PATH=./ssl/key.pem
# SSL_CERT_PATH=./ssl/cert.pem
