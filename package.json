{
  "name": "rt-backend",
  "version": "1.0.0",
  "description": "Rural Tourism Backend API - Tourism & Accommodation Management System",
  "private": true,
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node ./bin/www",
    "dev": "nodemon server.js",
    "server": "node server.js",
    "console": "node --experimental-repl-await scripts/console.js",
    "db:sync": "node -e \"require('./config/db')\"",
    "lint": "eslint .",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:unit": "jest tests/unit --coverage",
    "test:integration": "jest tests/integration --coverage",
    "test:middleware": "jest tests/unit/middleware",
    "test:routes": "jest tests/integration/routes"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "dotenv": "^16.4.5",
    "express": "~4.16.1",
    "http-errors": "~1.6.3",
    "jade": "~1.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "~1.9.1",
    "multer": "^1.4.5-lts.1",
    "mysql": "^2.18.1",
    "mysql2": "^3.11.3",
    "pdfkit": "^0.15.1",
    "puppeteer": "^23.11.1",
    "qs": "^6.14.1",
    "sequelize": "^6.37.5",
    "sequelize-paginate": "^1.1.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4"
  }
}
